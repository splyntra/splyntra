{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "separate-pull-requests": false,
  "include-component-in-tag": true,
  "packages": {
    "sdks/python": {
      "release-type": "python",
      "package-name": "splyntra",
      "extra-files": ["src/splyntra/__init__.py"],
      "changelog-path": "CHANGELOG.md",
      "release-as": "1.0.0"
    },
    "sdks/typescript": {
      "release-type": "node",
      "package-name": "@splyntra/sdk",
      "changelog-path": "CHANGELOG.md",
      "release-as": "1.0.0"
    },
    "apps/web": {
      "release-type": "node",
      "package-name": "@splyntra/dashboard",
      "changelog-path": "CHANGELOG.md",
      "release-as": "1.0.0"
    }
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "splyntra",
      "components": ["splyntra", "@splyntra/sdk"]
    }
  ]
}
