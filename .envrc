# direnv — auto-activate project environment on `cd`
# Install: brew install direnv && eval "$(direnv hook zsh)"
# Then: direnv allow

# Node.js (via fnm/nvm)
use_node() {
  local node_version
  node_version=$(cat .node-version 2>/dev/null)
  if command -v fnm &>/dev/null; then
    eval "$(fnm env --use-on-cd)"
    fnm use "$node_version" 2>/dev/null || fnm install "$node_version"
  elif [ -s "$HOME/.nvm/nvm.sh" ]; then
    source "$HOME/.nvm/nvm.sh"
    nvm use "$node_version" 2>/dev/null || nvm install "$node_version"
  fi
}

# Python (via pyenv)
use_python() {
  local python_version
  python_version=$(cat .python-version 2>/dev/null)
  if command -v pyenv &>/dev/null; then
    eval "$(pyenv init -)"
    pyenv shell "$python_version" 2>/dev/null
  fi
}

use_node
use_python

# Go
export GOBIN="$PWD/bin"
export PATH="$GOBIN:$PATH"

# Load .env for local development (if present)
dotenv_if_exists .env
