# ─── Splyntra (required) ─────────────────────────────────────────────
# API key for the project this service reports to. In Splyntra Cloud, mint
# this per-project under Settings → Keys; self-host dev accepts splyntra_dev_key.
SPLYNTRA_API_KEY=
# Logical project name traces are grouped under.
SPLYNTRA_PROJECT=
# Collector OTLP endpoint. Self-host default below; Cloud uses your ingest host.
SPLYNTRA_ENDPOINT=http://localhost:4318

# ─── Runtime ─────────────────────────────────────────────────────────
# production | staging | development — sets the trace environment label and
# turns on stricter startup checks. Defaults to development if unset.
NODE_ENV=production
PORT=8080
# Per-request budget. The agent aborts and returns 504 if it runs longer.
REQUEST_TIMEOUT_MS=15000

# ─── LLM provider (optional) ─────────────────────────────────────────
# Provider precedence: Gemini → OpenAI → simulated. Whichever key is set wins;
# with none set the service runs a clearly-labeled simulated completion so you
# can see traces flow without any provider account. All paths are auto-traced.

# Google Gemini (via its OpenAI-compatible endpoint — same SDK auto-instrument).
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=
# Override only if Google changes the compat host.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# OpenAI (used only when GEMINI_API_KEY is unset).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
