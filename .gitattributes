# Auto detect text files and normalise line endings to LF
* text=auto eol=lf

# Explicit text files
*.go text diff=golang
*.py text diff=python
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.yml text
*.yaml text
*.md text
*.sql text
*.html text
*.css text
*.sh text eol=lf
*.bash text eol=lf
Makefile text eol=lf
Taskfile.yml text
Dockerfile text
*.proto text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.gz binary

# Prevent generated files from showing in diffs / stats
bin/collector binary
**/dist/** linguist-generated
**/node_modules/** linguist-vendored

# Lock files — show in diff but mark generated
**/go.sum linguist-generated
**/package-lock.json linguist-generated
**/pnpm-lock.yaml linguist-generated
