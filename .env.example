# Environment variables for local development
# Copy to .env and customize

# ─── Collector ────────────────────────────────────────────────────────
PORT=4318
POSTGRES_DSN=postgres://splyntra:splyntra@localhost:5432/splyntra?sslmode=disable
NATS_URL=nats://localhost:4222
CLICKHOUSE_DSN=clickhouse://localhost:9000/splyntra
VALKEY_ADDR=localhost:6379
RATE_LIMIT_RPS=1000
CORS_ORIGINS=http://localhost:3000

# Postgres / ClickHouse credentials (compose interpolates these)
POSTGRES_USER=splyntra
POSTGRES_PASSWORD=splyntra
POSTGRES_DB=splyntra
CLICKHOUSE_USER=splyntra
CLICKHOUSE_PASSWORD=splyntra
CLICKHOUSE_DB=splyntra

# ─── Dashboard ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4318
COLLECTOR_URL=http://localhost:4318
EVAL_URL=http://localhost:8002
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-change-in-production

# ─── MinIO (Object Storage — eval datasets) ──────────────────────────
MINIO_ROOT_USER=splyntra
MINIO_ROOT_PASSWORD=splyntra123

# ─── Evaluation Service ──────────────────────────────────────────────
# Optional: enable the LLM-as-judge scorer (leave blank to use deterministic scorers only)
EVAL_LLM_API_KEY=
EVAL_LLM_MODEL=gpt-4o-mini

# ─── Detector Service ────────────────────────────────────────────────
DETECTOR_URL=http://localhost:8001
